from Api.Base.ExceptionsCode import OKXGENERALEXCEPTIONS

class OKXApiExceptions(Exception):
    def __init__(self, message):
        super().__init__(message)

class OKXApiExceptions:
    def __init__(self, response):
        self.response = response
        
        self.__check_response()

    def __check_response(self):
        if self.response_code != 0:
            for response_code, msg in OKXGENERALEXCEPTIONS['responce_code'], OKXGENERALEXCEPTIONS['msg']:
                if response_code == self.response_code:
                    raise OKXApiExceptions(f'Responce error: {self.response_code}\n{msg}')
                else:
                    raise ValueError(f'Responce error: {self.response_code}')
